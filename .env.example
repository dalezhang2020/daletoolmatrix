# ============================================================
# DaleToolMatrix Backend — Environment Variables
# Copy this file to backend/.env and fill in the values.
# Never commit the actual .env file.
# ============================================================

# ── Shared Infrastructure ────────────────────────────────────

# Neon PostgreSQL (shared across all tools)
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=

# ── AWS S3 (shared file storage for all tools) ───────────────
# Bucket: toolmatrix-s3, Region: us-east-1
# IAM user needs: s3:PutObject, s3:GetObject on the bucket
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=toolmatrix-s3
S3_REGION=us-east-1
# Upload paths per tool (used as path_prefix):
#   imagelingo/uploads/     — user-uploaded source images
#   imagelingo/translated/  — GPT Image translated results

# ── Tool: ImageLingo ─────────────────────────────────────────

# Shopline OAuth credentials
# Get from: https://partners.shopline.com → App → App Credentials
SHOPLINE_APP_KEY=
SHOPLINE_APP_SECRET=
# The backend URL (Railway) — used as the app entry point
SHOPLINE_APP_URL=https://positive-warmth-production.up.railway.app
# Must match the callback URL configured in Shopline Partners
SHOPLINE_REDIRECT_URI=https://positive-warmth-production.up.railway.app/api/imagelingo/auth/callback
# Set to 1 only in local dev to skip HMAC signature verification
SKIP_HMAC_VERIFY=0

# Vercel frontend URL — where users land after OAuth
FRONTEND_URL=https://web-seven-beta-49.vercel.app

# Azure OpenAI — primary image translation engine (GPT Image 2)
# Get from: Azure AI Foundry → your resource → Keys and Endpoint
AZURE_OPENAI_ENDPOINT=https://foundry-llm-zg.services.ai.azure.com/openai/v1
AZURE_OPENAI_API_KEY=
# Deployment name as configured in Azure AI Foundry
AZURE_OPENAI_IMAGE_DEPLOYMENT=gpt-image-2-1
# Speed/quality tuning: low|medium|high
AZURE_OPENAI_IMAGE_QUALITY=medium
# Source image max dimension before calling GPT Image (smaller = faster)
IMAGELINGO_SOURCE_MAX_DIM=1024

# Lovart — fallback image translation engine
# Get from: https://lovart.ai → Settings → AK/SK Management
# Used only when AZURE_OPENAI_API_KEY is not set
LOVART_ACCESS_KEY=
LOVART_SECRET_KEY=
LOVART_BASE_URL=https://lgw.lovart.ai
# Set to 1 to skip SSL verification (dev only)
LOVART_INSECURE_SSL=0

# ── Tool: Shopline-Zendesk ───────────────────────────────────

# Shopline OAuth credentials (separate app from ImageLingo)
# Get from: https://partners.shopline.com → App → App Credentials
SHOPLINE_ZD_APP_KEY=
SHOPLINE_ZD_APP_SECRET=
# Vercel frontend URL — where merchants land after OAuth
SHOPLINE_ZD_FRONTEND_URL=https://shopline-zendesk-frontend.vercel.app
# Set to 1 only in local dev to skip HMAC signature verification
SHOPLINE_ZD_SKIP_HMAC=0

# ── Tool: Content Collector ──────────────────────────────────

# Optional — defaults to shared DATABASE_URL. Override if you want the tool on
# a separate Neon branch.
CONTENT_COLLECTOR_DATABASE_URL=

# Flip to "false" in dev if you don't want sources fetching in the background.
CONTENT_COLLECTOR_SCHEDULER_ENABLED=true

# Keep this many days of items (tunable; 14 is safe for a 7-day window).
CONTENT_COLLECTOR_RETENTION_DAYS=14

# HTTP client tuning
CONTENT_COLLECTOR_HTTP_TIMEOUT=10

# Product Hunt API — free, 5 min signup at https://api.producthunt.com/v2/docs
PRODUCTHUNT_API_TOKEN=

# Zhihu cookie — optional; without it we get a shorter hot list (20 vs 50).
CONTENT_COLLECTOR_ZHIHU_COOKIE=

# LLM classifier — reuses ImageLingo's Azure OpenAI resource. Add a chat-capable
# model (gpt-4o-mini is enough; <$0.20/day at 15 sources × 24h).
# Leaving AZURE_OPENAI_CHAT_MODEL empty uses 'gpt-4o-mini' by default.
AZURE_OPENAI_CHAT_MODEL=gpt-4o-mini

# Reddit OAuth2 app-only (optional but strongly recommended for cloud deploys).
# Anonymous Reddit JSON is 403'd from most datacenter IPs (Railway/Vercel).
# Create a "script" app at https://www.reddit.com/prefs/apps (2 min).
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
